# data: 모든 실제 내용물 제외, 폴더와 .gitkeep만 허용
data/**/*
!data/**/
!data/**/.gitkeep

# results: 모든 실제 내용물 제외, 폴더와 .gitkeep만 허용
results/**/*
!results/**/
!results/**/.gitkeep

# Temporary
tmp/
temp/
*.log
